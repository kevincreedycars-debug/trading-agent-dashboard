{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kevincreedycars-debug.github.io/trading-agent-dashboard/data/architecture-map.schema.json",
  "title": "Architecture Mirror Manifest",
  "type": "object",
  "required": [
    "metadata",
    "nodes",
    "edges",
    "views",
    "legends",
    "boundaries"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "title",
        "version",
        "generated_from",
        "last_verified_at"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_from": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "last_verified_at": { "type": "string", "minLength": 1 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "views": {
      "type": "array",
      "items": { "$ref": "#/$defs/view" }
    },
    "legends": {
      "type": "array",
      "items": { "$ref": "#/$defs/legend" }
    },
    "boundaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary" }
    }
  },
  "$defs": {
    "verification": {
      "type": "object",
      "required": [
        "status",
        "evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "partially_verified",
            "unverified"
          ]
        },
        "evidence": { "type": "string", "minLength": 1 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "label",
        "kind",
        "summary",
        "verification"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "short_label": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "details": { "type": "string" },
        "files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "verification": { "$ref": "#/$defs/verification" }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": [
        "id",
        "source",
        "target",
        "label",
        "verification"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "details": { "type": "string" },
        "verification": { "$ref": "#/$defs/verification" }
      },
      "additionalProperties": true
    },
    "boundary": {
      "type": "object",
      "required": [
        "id",
        "label",
        "description"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "legend": {
      "type": "object",
      "required": [
        "id",
        "title",
        "items"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "description"
            ],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "view": {
      "type": "object",
      "required": [
        "id",
        "label",
        "description",
        "node_ids",
        "edge_ids",
        "boundary_ids",
        "layout"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "node_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "edge_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "boundary_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout": {
          "type": "object",
          "required": [
            "width",
            "height",
            "nodes",
            "boundaries"
          ],
          "properties": {
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "nodes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": [
                  "x",
                  "y"
                ],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                },
                "additionalProperties": true
              }
            },
            "boundaries": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": [
                  "x",
                  "y",
                  "width",
                  "height"
                ],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "width": { "type": "number", "exclusiveMinimum": 0 },
                  "height": { "type": "number", "exclusiveMinimum": 0 }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
