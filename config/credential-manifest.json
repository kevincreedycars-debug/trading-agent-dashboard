{
  "$schema": "./credential-manifest.schema.json",
  "manifest_version": "1.0.0",
  "updated_at": "2026-07-20",
  "entries": [
    {
      "name": "N8N_BASE_URL",
      "availability": "required",
      "classification": "non_secret_configuration",
      "secret": false,
      "required": true,
      "required_for": [
        "n8n"
      ],
      "consumers": [
        "mcp-n8n/src/server.ts",
        "mcp-n8n/README.md"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": "Process environment variable set manually for the current shell",
      "validation": {
        "kind": "uri",
        "allow_empty": false,
        "pattern": "^https://"
      },
      "notes": "Required n8n endpoint configuration stored alongside the encrypted local credential set."
    },
    {
      "name": "N8N_API_KEY",
      "availability": "required",
      "classification": "private_credential",
      "secret": true,
      "required": true,
      "required_for": [
        "n8n"
      ],
      "consumers": [
        "mcp-n8n/src/server.ts",
        "mcp-n8n/README.md"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": null,
      "validation": {
        "kind": "nonempty",
        "allow_empty": false,
        "pattern": null
      },
      "notes": "Required private API credential for the connected n8n workspace."
    },
    {
      "name": "SUPABASE_URL",
      "availability": "required",
      "classification": "non_secret_configuration",
      "secret": false,
      "required": true,
      "required_for": [
        "backtester",
        "market-importers"
      ],
      "consumers": [
        "backtester/lib/historical_common.js",
        "backtester/builders/*",
        "backtester/importers/*",
        "backtester/replay/*",
        "backtester/scripts/*",
        "backtester/tests/*"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": "Supabase CLI helper for specific test and helper scripts only",
      "validation": {
        "kind": "uri",
        "allow_empty": false,
        "pattern": "^https://"
      },
      "notes": "Required Supabase project endpoint for backtester and importer workflows."
    },
    {
      "name": "SUPABASE_SERVICE_ROLE_KEY",
      "availability": "required",
      "classification": "private_credential",
      "secret": true,
      "required": true,
      "required_for": [
        "backtester",
        "market-importers"
      ],
      "consumers": [
        "backtester/lib/historical_common.js",
        "backtester/builders/*",
        "backtester/importers/*",
        "backtester/replay/*",
        "backtester/scripts/*",
        "backtester/tests/*"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": "Supabase CLI helper for backtester/scripts/run_with_linked_supabase_env.js and linked tests",
      "validation": {
        "kind": "nonempty",
        "allow_empty": false,
        "pattern": null
      },
      "notes": "Required privileged service-role key for repository research and import paths."
    },
    {
      "name": "FRED_API_KEY",
      "availability": "required",
      "classification": "private_credential",
      "secret": true,
      "required": true,
      "required_for": [
        "market-importers"
      ],
      "consumers": [
        "backtester/importers/fred/import_fred_macro.js",
        "backtester/importers/eurusd/import_eurusd_daily.js",
        "backtester/importers/gold/import_gold_daily.js",
        "backtester/importers/fred/README.md"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": null,
      "validation": {
        "kind": "nonempty",
        "allow_empty": false,
        "pattern": null
      },
      "notes": "Required for importer paths that call the FRED API directly."
    },
    {
      "name": "RAPIDAPI_KEY",
      "availability": "required",
      "classification": "private_credential",
      "secret": true,
      "required": true,
      "required_for": [
        "market-importers"
      ],
      "consumers": [
        "backtester/importers/usd_events/import_usd_events.js"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": null,
      "validation": {
        "kind": "nonempty",
        "allow_empty": false,
        "pattern": null
      },
      "notes": "Required for the RapidAPI-backed market importer path."
    },
    {
      "name": "ALPHA_VANTAGE_API_KEY",
      "availability": "optional",
      "classification": "private_credential",
      "secret": true,
      "required": false,
      "required_for": [
        "market-importers"
      ],
      "consumers": [
        "backtester/importers/eurusd/download_eurusd_daily_ohlc_alpha_vantage.js"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": "Script-level demo key fallback",
      "validation": {
        "kind": "optional_nonempty",
        "allow_empty": true,
        "pattern": null
      },
      "notes": "Optional because the importer supports a vendor demo key fallback."
    },
    {
      "name": "OANDA_API_TOKEN",
      "availability": "required",
      "classification": "private_credential",
      "secret": true,
      "required": true,
      "required_for": [
        "market-importers"
      ],
      "consumers": [
        "backtester/importers/oanda/download_oanda_candles.js"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": null,
      "validation": {
        "kind": "nonempty",
        "allow_empty": false,
        "pattern": null
      },
      "notes": "Required private OANDA API token for historical candle acquisition."
    },
    {
      "name": "OANDA_ACCOUNT_ID",
      "availability": "conditional",
      "classification": "non_secret_configuration",
      "secret": false,
      "required": false,
      "required_for": [
        "market-importers"
      ],
      "consumers": [
        "backtester/importers/oanda/download_oanda_candles.js"
      ],
      "preferred_source": "Encrypted local CLIXML credential store",
      "fallback_source": "CLI --account-id argument",
      "validation": {
        "kind": "optional_nonempty",
        "allow_empty": true,
        "pattern": null
      },
      "notes": "Conditional account identifier required only for OANDA instrument-list enumeration."
    }
  ]
}
