{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agent-dashboard.local/schemas/credential-manifest.schema.json",
  "title": "Trading Agent Dashboard Credential Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "updated_at",
    "entries"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "availability",
        "classification",
        "secret",
        "required",
        "required_for",
        "consumers",
        "preferred_source",
        "fallback_source",
        "validation",
        "notes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "availability": {
          "type": "string",
          "enum": [
            "required",
            "optional",
            "conditional"
          ]
        },
        "classification": {
          "type": "string",
          "enum": [
            "private_credential",
            "non_secret_configuration"
          ]
        },
        "secret": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "required_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "preferred_source": {
          "type": "string",
          "minLength": 1
        },
        "fallback_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "allow_empty"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "uri",
                "nonempty",
                "optional_nonempty"
              ]
            },
            "allow_empty": {
              "type": "boolean"
            },
            "pattern": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
