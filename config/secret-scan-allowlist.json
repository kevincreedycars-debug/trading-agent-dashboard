{
  "version": "1.0.0",
  "rules": [
    {
      "path_regex": "^script\\.js$",
      "line_regex": "researchSupabaseKey",
      "reason": "Intentional browser-facing Supabase publishable key. Review separately from private credential scanning."
    },
    {
      "path_regex": "^backtester/tests/secret_scanner\\.test\\.js$",
      "line_regex": "BEGIN PRIVATE KEY|gh[p]_FAKEPLACEHOLDERTOKENVALUE|PLACEHOLDERSECRET123456|PLACEHOLDERBEARERTOKEN1234567890|PLACEHOLDERENVVALUE123456|UNTRACKEDPLACEHOLDER123456|STAGEDPLACEHOLDER123456|QUIETPLACEHOLDER123456|gh[p]_SHOULDNOTAPPEARINOUTPUT1234567890",
      "reason": "Synthetic placeholder fixtures for repository secret-scanner tests."
    }
  ]
}
